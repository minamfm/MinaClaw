#   google-chrome --remote-debugging-port=9222
CHROME_CDP_URL=ws://localhost:9222

# ── Web search (optional) ─────────────────────────────
BRAVE_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
