# ── Required ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── LLM providers (add the ones you use) ──────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
KIMI_API_KEY=
DEEPSEEK_API_KEY=

# ── Local / self-hosted ────────────────────────────────
OLLAMA_URL=http://localhost:11434

# ── Browser learning (/learn command) ─────────────────
